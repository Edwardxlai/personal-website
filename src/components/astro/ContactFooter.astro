---
import { Image } from 'astro:assets';
import { contact } from '../../data/site';
import wechatQr from '../../assets/contact/wechat-qr.jpg';

// 跑马灯词条（气氛件，参考 sac-ai.com 的 contact marquee）
const marqueeWords = 'AI WORKFLOW · 下一代内容 · CONTENT SYSTEMS · 写 / 拍 / 构建 · BUILD IN PUBLIC · ';
---

<section class="section container contact" aria-labelledby="contact">
  <div class="contact-marquee" aria-hidden="true">
    <div class="mq-track">
      <span class="mq-set">{marqueeWords.repeat(3)}</span>
      <span class="mq-set">{marqueeWords.repeat(3)}</span>
    </div>
  </div>

  <div class="contact-grid">
    <div class="contact-main">
      <h2 id="contact" class="contact-headline reveal">{contact.headline}</h2>

      <button
        class="contact-wechat reveal glare-hover"
        type="button"
        data-copy={contact.wechat}
        aria-label={`复制微信号 ${contact.wechat}`}
        data-magnet
      >
        <span class="wx-meta">
          <span class="wx-kicker">WECHAT</span>
          <span class="wx-label">微信 · 推荐联系</span>
        </span>
        <span class="wx-id">{contact.wechat}</span>
        <span class="wx-action" data-copy-label>复制微信号</span>
      </button>

      <div class="contact-email reveal">
        <a class="email-link glare-hover" href={`mailto:${contact.email}`} data-magnet>
          {contact.email} <span class="arrow" aria-hidden="true">↗</span>
        </a>
        <button class="copy-btn glare-hover" data-copy={contact.email} aria-label="复制邮箱" data-magnet>
          复制
        </button>
      </div>

      <nav class="contact-links reveal" aria-label="社交链接">
        {contact.links.map((l) => (
          <a class="glare-hover" href={l.href} target="_blank" rel="noopener noreferrer" data-magnet>{l.label}</a>
        ))}
      </nav>
    </div>

    <figure class="contact-qr reveal">
      <span class="qr-frame">
        <span class="qr-tick qr-tick--tl" aria-hidden="true"></span>
        <span class="qr-tick qr-tick--br" aria-hidden="true"></span>
        <Image src={wechatQr} alt="微信二维码：Edward" widths={[240, 480]} sizes="240px" />
      </span>
      <figcaption>WECHAT · 扫码直达</figcaption>
    </figure>
  </div>
</section>

<style>
  .contact { padding-top: 180px; }

  /* ---- 跑马灯气氛条 ---- */
  .contact-marquee {
    overflow: hidden;
    border-top: 1px solid var(--line-subtle);
    border-bottom: 1px solid var(--line-subtle);
    padding-block: var(--space-3);
    margin-bottom: clamp(56px, 8vw, 120px);
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
  }
  .mq-track {
    display: flex;
    width: max-content;
    animation: mq-scroll 36s linear infinite;
  }
  .mq-set {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: 0.14em;
    color: var(--text-tertiary);
    white-space: nowrap;
    padding-right: 1em;
  }
  @keyframes mq-scroll {
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .mq-track { animation: none; }
  }

  /* ---- 主体 + 二维码双栏 ---- */
  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: clamp(32px, 6vw, 96px);
    align-items: end;
  }

  .contact-qr {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    width: clamp(180px, 18vw, 240px);
  }
  .qr-frame {
    position: relative;
    display: block;
    border-radius: var(--radius-md);
    overflow: visible;
    transition:
      transform 260ms var(--ease-out),
      box-shadow 260ms var(--ease-out);
  }
  .qr-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, transparent 0 38%, rgba(183, 247, 42, 0.18) 48%, transparent 58%),
      radial-gradient(180px circle at 50% 8%, rgba(183, 247, 42, 0.12), transparent 72%);
    border-radius: inherit;
    opacity: 0;
    transform: translateY(-42%);
    transition:
      opacity 220ms var(--ease-out),
      transform 820ms var(--ease-out);
    mix-blend-mode: screen;
  }
  .contact-qr :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    box-shadow: inset 0 0 0 1px var(--line-strong);
    background: var(--surface-1);
    transition:
      filter 260ms var(--ease-out),
      transform 260ms var(--ease-out);
  }
  .contact-qr figcaption {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--text-tertiary);
    text-align: center;
  }
  .qr-tick {
    position: absolute;
    width: 14px;
    height: 14px;
    pointer-events: none;
    z-index: 1;
  }
  .qr-tick--tl {
    top: -7px;
    left: -7px;
    border-top: 2px solid var(--accent);
    border-left: 2px solid var(--accent);
  }
  .qr-tick--br {
    right: -7px;
    bottom: -7px;
    border-bottom: 2px solid var(--accent);
    border-right: 2px solid var(--accent);
  }
  @media (hover: hover) {
    .contact-qr:hover .qr-frame {
      transform: translateY(-5px);
      box-shadow: 0 18px 54px rgba(0, 0, 0, 0.24);
    }
    .contact-qr:hover .qr-frame::after {
      opacity: 1;
      transform: translateY(42%);
    }
    .contact-qr:hover :global(img) {
      filter: brightness(1.08) contrast(1.05);
      transform: scale(1.015);
    }
  }

  @media (max-width: 767px) {
    .contact-grid { grid-template-columns: 1fr; align-items: start; }
    .contact-qr { order: 2; }
  }

  .contact-headline {
    font-family: var(--font-serif-cn);
    font-size: clamp(36px, 5.8vw, 86px);
    font-weight: 900;
    line-height: 1.12;
    letter-spacing: -0.018em;
    max-width: 18ch;
    text-wrap: balance;
  }

  .contact-wechat {
    display: grid;
    grid-template-columns: minmax(120px, auto) minmax(0, 1fr) auto;
    align-items: center;
    gap: clamp(14px, 3vw, 36px);
    margin-top: var(--space-12);
    width: min(100%, 780px);
    min-height: clamp(86px, 9vw, 124px);
    padding: clamp(14px, 2.2vw, 24px) clamp(16px, 2.8vw, 32px);
    background:
      linear-gradient(180deg, oklch(1 0 0 / 0.035), transparent),
      var(--layer-1);
    border: 1px solid var(--line-subtle);
    border-radius: var(--radius-lg);
    color: inherit;
    cursor: pointer;
    text-align: left;
    --glare-radius: var(--radius-lg);
    --glare-size: 460px;
    box-shadow: inset 0 1px 0 oklch(1 0 0 / 0.045);
    transition:
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out),
      box-shadow 220ms var(--ease-out),
      transform 220ms var(--ease-out);
  }
  .wx-meta {
    display: grid;
    gap: 4px;
  }
  .wx-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--accent);
  }
  .wx-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }
  .wx-id {
    font-family: var(--font-mono);
    font-size: clamp(30px, 4.8vw, 62px);
    font-weight: 420;
    color: var(--text-primary);
    letter-spacing: -0.055em;
    line-height: 0.9;
    font-variant-numeric: tabular-nums;
  }
  .wx-action {
    justify-self: end;
    min-width: 88px;
    padding: 8px 12px;
    border: 1px solid var(--line-subtle);
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    text-align: center;
    white-space: nowrap;
    transition:
      border-color 220ms var(--ease-out),
      color 220ms var(--ease-out),
      background 220ms var(--ease-out);
  }
  .contact-wechat:hover {
    border-color: rgba(183, 247, 42, 0.3);
    background: var(--layer-2);
    box-shadow:
      inset 0 1px 0 oklch(1 0 0 / 0.07),
      0 18px 54px rgba(0, 0, 0, 0.18);
  }
  .contact-wechat:hover .wx-action,
  .contact-wechat.copied .wx-action {
    color: var(--accent);
    border-color: rgba(183, 247, 42, 0.38);
    background: rgba(183, 247, 42, 0.06);
  }
  .contact-wechat.copied {
    border-color: rgba(183, 247, 42, 0.44);
  }

  @media (max-width: 767px) {
    .contact-wechat {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .wx-id {
      font-size: clamp(32px, 11vw, 48px);
      letter-spacing: -0.045em;
      overflow-wrap: anywhere;
    }
    .wx-action {
      justify-self: start;
    }
  }

  .contact-email {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-8);
    flex-wrap: wrap;
  }

  .email-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 44px);
    font-weight: 620;
    color: var(--accent);
    word-break: break-all;
    padding: 4px 8px;
    margin: -4px -8px;
    --glare-radius: var(--radius-sm);
  }
  .email-link .arrow { transition: transform var(--dur-hover) var(--ease-out); }
  .email-link:hover .arrow { transform: translate(6px, -6px); }

  .copy-btn {
    background: none;
    border: 1px solid var(--line-subtle);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    cursor: pointer;
    color: var(--text-secondary);
    min-height: 44px;
    --glare-radius: var(--radius-pill);
    transition: border-color var(--dur-hover) var(--ease-out);
  }
  .copy-btn:hover { border-color: var(--line-strong); }
  .copy-btn.copied { color: var(--accent); border-color: var(--accent); }

  .contact-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    margin-top: var(--space-12);
    color: var(--text-secondary);
  }
  .contact-links a {
    padding: 5px 8px;
    margin: -5px -8px;
    --glare-radius: var(--radius-sm);
    transition: color var(--dur-hover) var(--ease-out);
  }
  .contact-links a:hover { color: var(--text-primary); }
</style>

<script>
  // 复制联系方式：成功显示行内文字，不用 toast / 模态框 (DESIGN §06)
  document.querySelectorAll<HTMLElement>('[data-copy]').forEach((control) => {
    control.addEventListener('click', async () => {
      const value = control.dataset.copy;
      if (!value) return;
      const label = control.querySelector<HTMLElement>('[data-copy-label]') ?? control;
      try {
        await navigator.clipboard.writeText(value);
        const prev = label.textContent;
        label.textContent = '已复制';
        control.classList.add('copied');
        setTimeout(() => {
          label.textContent = prev;
          control.classList.remove('copied');
        }, 1600);
      } catch {
        /* 剪贴板不可用时静默：邮箱链接仍可点击，微信号仍可手动复制 */
      }
    });
  });
</script>
