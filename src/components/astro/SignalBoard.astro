---
import SectionHeading from './SectionHeading.astro';
import { signalBoard } from '../../data/site';

// 信号条静态高度节奏（纯装饰，不编码数据）
const BAR_COUNT = 7;
---

<section class="section container" aria-labelledby="content">
  <SectionHeading id="content" eyebrow="Signal board" index="S / 03" title="全平台信号台" />

  <ul class="sb-list" role="list">
    {signalBoard.map((s, i) => (
      <li class="sb-row reveal" style={`--reveal-i:${i}`}>
        <a class="sb-link glare-hover" href={s.href} target="_blank" rel="noopener noreferrer" data-magnet>
          <span class="sb-live"><i aria-hidden="true"></i>{s.status}</span>

          <span class="sb-id">
            <span class="sb-platform">{s.platform}</span>
            <span class="sb-tagline">
              <span class="sb-tag">{s.tag}</span>
              <span class="sb-blurb">{s.blurb}</span>
            </span>
          </span>

          <span class="sb-bars" aria-hidden="true">
            {Array.from({ length: BAR_COUNT }).map(() => <i></i>)}
          </span>

          <span class="sb-stat">
            <b>{s.stat}</b>
            <em>{s.statLabel}</em>
          </span>

          <span class="sb-arrow" aria-hidden="true">↗</span>
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .sb-list { display: flex; flex-direction: column; }
  .sb-row { border-top: 1px solid var(--line-subtle); }
  .sb-row:last-child { border-bottom: 1px solid var(--line-subtle); }

  .sb-link {
    position: relative;
    display: grid;
    grid-template-columns: 64px minmax(0, 1fr) auto minmax(148px, auto) 24px;
    align-items: center;
    gap: var(--space-6);
    min-height: 104px;
    padding-block: var(--space-4);
    padding-inline: var(--space-3);
    margin-inline: calc(var(--space-3) * -1);
    border-radius: var(--radius-md);
    --glare-radius: var(--radius-md);
    --glare-size: 420px;
    transition:
      background var(--dur-hover) var(--ease-out),
      transform 220ms var(--ease-out);
  }

  /* ---- LIVE 状态灯 ---- */
  .sb-live {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    color: var(--text-tertiary);
  }
  .sb-live i {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 10px var(--accent);
    animation: sb-pulse 2.4s var(--ease-out) infinite;
  }
  @keyframes sb-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  /* ---- 平台名 + 说明 ---- */
  .sb-id { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .sb-platform {
    font-family: var(--font-display);
    font-size: var(--fs-project);
    font-weight: 620;
    letter-spacing: -0.018em;
    line-height: 1;
    transition: color var(--dur-hover) var(--ease-out);
  }
  .sb-tagline { display: flex; align-items: baseline; gap: var(--space-3); }
  .sb-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    color: var(--accent);
    opacity: 0.75;
  }
  .sb-blurb {
    font-size: var(--fs-meta);
    color: var(--text-tertiary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ---- 信号条（装饰性均衡器） ---- */
  .sb-bars {
    display: inline-flex;
    align-items: flex-end;
    gap: 3px;
    height: 26px;
  }
  .sb-bars i {
    width: 3px;
    background: var(--accent);
    opacity: 0.3;
    transform-origin: bottom;
    animation: sb-eq 2.8s var(--ease-out) infinite;
    transition: opacity var(--dur-hover) var(--ease-out);
  }
  .sb-bars i:nth-child(1) { height: 30%; }
  .sb-bars i:nth-child(2) { height: 55%; }
  .sb-bars i:nth-child(3) { height: 40%; }
  .sb-bars i:nth-child(4) { height: 75%; }
  .sb-bars i:nth-child(5) { height: 50%; }
  .sb-bars i:nth-child(6) { height: 90%; }
  .sb-bars i:nth-child(7) { height: 62%; }
  .sb-bars i:nth-child(2n) { animation-delay: 0.15s; }
  .sb-bars i:nth-child(3n) { animation-delay: 0.32s; }
  @keyframes sb-eq {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(0.58); }
  }

  /* ---- 巨号数据（唬人但真实） ---- */
  .sb-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
  }
  .sb-stat b {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: clamp(30px, 3.6vw, 52px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
    transition: color var(--dur-hover) var(--ease-out);
  }
  .sb-stat em {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-tertiary);
  }

  .sb-arrow {
    color: var(--text-tertiary);
    transition: transform var(--dur-hover) var(--ease-out), color var(--dur-hover) var(--ease-out);
  }

  /* ---- 悬停：整行点亮，信号条起舞 ---- */
  @media (hover: hover) {
    .sb-link:hover {
      background: var(--layer-1);
      transform: translate3d(var(--magnet-x), var(--magnet-y), 0);
    }
    .sb-link:hover .sb-platform { color: var(--accent); }
    .sb-link:hover .sb-stat b { color: var(--accent); }
    .sb-link:hover .sb-arrow { color: var(--accent); transform: translate(4px, -4px); }
    .sb-link:hover .sb-bars i {
      opacity: 0.9;
      animation-duration: 0.9s;
    }
    .sb-link:hover .sb-bars i:nth-child(2n) { animation-delay: 0.12s; }
    .sb-link:hover .sb-bars i:nth-child(3n) { animation-delay: 0.24s; }
  }

  @media (max-width: 899px) {
    .sb-bars { display: none; }
    .sb-link { grid-template-columns: 48px minmax(0, 1fr) auto 20px; }
  }

  @media (max-width: 639px) {
    .sb-link {
      grid-template-columns: minmax(0, 1fr) auto;
      grid-template-areas:
        'live arrow'
        'id stat';
      row-gap: var(--space-3);
      min-height: 0;
      padding-block: var(--space-6);
    }
    .sb-live { grid-area: live; }
    .sb-arrow { grid-area: arrow; justify-self: end; }
    .sb-id { grid-area: id; }
    .sb-stat { grid-area: stat; align-self: end; }
    .sb-blurb { white-space: normal; }
  }
</style>
