---
// 自托管字体（fontsource）。Noto 按字重的 unicode-range 分片，浏览器只下载用到的中文子集。
import '@fontsource-variable/archivo/wght.css';
import '@fontsource-variable/jetbrains-mono/wght.css';
import '@fontsource/noto-sans-sc/400.css';
import '@fontsource/noto-sans-sc/500.css';
import '@fontsource/noto-sans-sc/700.css';
import '@fontsource/noto-serif-sc/700.css';
import '@fontsource/noto-serif-sc/900.css';

import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/motion.css';
import Nav from '../components/astro/Nav.astro';
import Footer from '../components/astro/Footer.astro';
import { identity } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  /** 是否显示锚点导航（首页用 true，内页用 false 显示返回链接由页面自管） */
  showNav?: boolean;
}

const {
  title,
  description = identity.roleZh,
  showNav = true,
} = Astro.props;

const pageTitle = title
  ? `${title} · ${identity.nameZh}`
  : `${identity.nameZh} · ${identity.roleEn}`;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="zh-CN" class="no-js">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / 分享卡片 (TODO: 补充 og:image 设计图) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <meta name="generator" content={Astro.generator} />

    <!-- 标记 JS 可用，供 .reveal 进入动画接管（无 JS 时保持可见，见 motion.css） -->
    <script is:inline>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <div class="cursor-ambient" aria-hidden="true"></div>
    <a href="#main" class="skip-link">Skip to content</a>
    {showNav && <Nav />}
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // 区块进入动画：IntersectionObserver 切换 .is-visible。
      // reduced-motion 下 CSS 已让 .reveal 直接显现，这里仍执行但视觉无位移。
      const els = document.querySelectorAll('.reveal');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }

      const hoverTargets = document.querySelectorAll<HTMLElement>('.glare-hover');
      const magnetTargets = document.querySelectorAll<HTMLElement>('[data-magnet]');
      const canMagnet = window.matchMedia('(hover: hover) and (pointer: fine) and (prefers-reduced-motion: no-preference)');
      const root = document.documentElement;

      hoverTargets.forEach((target) => {
        target.addEventListener('pointermove', (event) => {
          const rect = target.getBoundingClientRect();
          target.style.setProperty('--hover-x', `${((event.clientX - rect.left) / rect.width) * 100}%`);
          target.style.setProperty('--hover-y', `${((event.clientY - rect.top) / rect.height) * 100}%`);
        });
      });

      magnetTargets.forEach((target) => {
        target.addEventListener('pointermove', (event) => {
          if (!canMagnet.matches) return;
          const rect = target.getBoundingClientRect();
          const x = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
          const y = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
          target.style.setProperty('--magnet-x', `${(x * 4).toFixed(2)}px`);
          target.style.setProperty('--magnet-y', `${(y * 4).toFixed(2)}px`);
        });
        target.addEventListener('pointerleave', () => {
          target.style.setProperty('--magnet-x', '0px');
          target.style.setProperty('--magnet-y', '0px');
        });
      });

      const updateCursorAmbient = (event: PointerEvent) => {
        if (!canMagnet.matches) return;
        root.style.setProperty('--cursor-x', `${event.clientX}px`);
        root.style.setProperty('--cursor-y', `${event.clientY}px`);
        root.classList.add('is-pointer-active');
      };

      window.addEventListener('pointermove', updateCursorAmbient, { passive: true });
      window.addEventListener('pointerleave', () => {
        root.classList.remove('is-pointer-active');
      });
    </script>
  </body>
</html>
