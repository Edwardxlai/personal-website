---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面走丢了" showNav={false}>
  <section class="container notfound">
    <p class="eyebrow">404</p>
    <h1>这一页还不存在</h1>
    <p class="text-secondary measure">
      链接可能已经更新，或者这里的内容还没有做出来。
    </p>
    <a href="/" class="btn">返回首页</a>
  </section>
</BaseLayout>

<style>
  .notfound {
    min-height: 80svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-4);
  }
  .notfound h1 {
    font-size: var(--fs-display);
    letter-spacing: -0.032em;
  }
  .notfound .btn { margin-top: var(--space-6); align-self: flex-start; }
</style>
